# ── Server ─────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=production

# ── JWT ────────────────────────────────────────────────────────────────────
JWT_SECRET=CHANGE_THIS_MINIMUM_64_CHARS_LONG_SECRET_KEY_HERE
JWT_EXPIRES_IN=30d

# ── Firebase ───────────────────────────────────────────────────────────────
FIREBASE_SERVICE_ACCOUNT=./firebase-service-account.json

# ── Admin (Super Admin - يدير كل المدارس) ──────────────────────────────────
ADMIN_EMAIL=superadmin@tarabix.com
ADMIN_PASSWORD=Admin@2024!

# ── AI (اختياري) ──────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...

# ── Uploads ────────────────────────────────────────────────────────────────
UPLOADS_PATH=./uploads
MAX_FILE_MB=10
